APP_ENV=development
SECRET_KEY=replace_with_a_long_random_secret
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-frontend-domain.vercel.app
SQLITE_PATH=backend/data/tez_news.db
RPC_URL=https://sepolia.infura.io/v3/your-project-id
PRIVATE_KEY=your_wallet_private_key
CONTRACT_ADDRESS=0xYourSepoliaContractAddress
CHAIN_ID=11155111
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-flash-latest
GEMINI_TIMEOUT_SECONDS=30
GEMINI_USE_GOOGLE_SEARCH=true
# Optional if you move artifacts:
# BLOCKCHAIN_ARTIFACT_PATH=C:\absolute\path\to\NewsVerification.json
